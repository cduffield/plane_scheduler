<% Current.meta_tags.set(title: "New Maintenance Inspection") %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to @airplane.n_number.presence || "Airplane ##{@airplane.id}", airplane_path(@airplane) %></p>
        <h1 class="h3">New Maintenance Inspection</h1>
      </div>
    </div>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render "form", airplane: @airplane, maintenance_inspection: @maintenance_inspection %>
  </div>
</div>
