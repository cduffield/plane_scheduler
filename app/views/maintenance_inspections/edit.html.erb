<% Current.meta_tags.set(title: "Edit Maintenance Inspection") %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to @airplane.n_number.presence || "Airplane ##{@airplane.id}", airplane_path(@airplane) %></p>
        <h1 class="h3">Edit Maintenance Inspection</h1>
      </div>
    </div>
    <%= button_to t("delete"), airplane_maintenance_inspection_path(@airplane, @maintenance_inspection), method: :delete, class: "btn btn-secondary", form: { data: { turbo_confirm: t("are_you_sure") } } %>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render "form", airplane: @airplane, maintenance_inspection: @maintenance_inspection %>
  </div>
</div>
