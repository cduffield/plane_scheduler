<% Current.meta_tags.set(title: "Events ##{@event.id}") %>
<%= turbo_stream_from @event %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to "Events", events_path %></p>
        <h1 class="h3">Event #<%= @event.id %></h1>
      </div>
    </div>
    <%= link_to t("edit"), edit_event_path(@event), class: "btn btn-secondary" %>
  </div>

  <div class="mb-6 flex flex-wrap items-start gap-3">
    <% if @event.scheduled? %>
      <%= button_to "Open Flight", open_flight_event_path(@event), method: :patch, class: "btn btn-primary" %>
    <% elsif @event.open? %>
      <div class="sky-card sky-card-pad w-full max-w-xl">
        <h2 class="sky-section-title mb-4">Close Flight</h2>
        <%= render "error_messages", resource: @event %>

        <%= form_with model: @event, url: close_flight_event_path(@event), method: :patch do |form| %>
          <div class="form-group">
            <%= form.label :hobbs_end %>
            <%= form.number_field :hobbs_end, class: "form-control", step: 0.1 %>
          </div>

          <div class="form-group">
            <%= form.label :tach_end %>
            <%= form.number_field :tach_end, class: "form-control", step: 0.1 %>
          </div>

          <div class="flex items-center gap-3">
            <%= form.button "Close Flight", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    <% elsif @event.closed? %>
      <div class="sky-card sky-card-pad w-full max-w-xl">
        <h2 class="sky-section-title mb-4">Payment</h2>

        <div class="mb-4 text-sm sky-muted">
          Total due:
          <span class="font-semibold"><%= @event.total_cost.present? ? number_to_currency(@event.total_cost) : "Not available yet" %></span>
        </div>

        <% if @event_payment&.paid? %>
          <p class="sky-badge">
            Paid <%= @event_payment.paid_at.present? ? l(@event_payment.paid_at, format: :long) : "" %>
          </p>
        <% elsif @event.total_cost.present? && @event.total_cost > 0 %>
          <%= button_to "Pay with Stripe Checkout", event_payment_path(@event), method: :post, class: "btn btn-primary", form: { data: { turbo: false } } %>
        <% else %>
          <p class="text-sm sky-muted">Close the flight with valid Hobbs readings to generate a payable total.</p>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render @event %>
  </div>
</div>
