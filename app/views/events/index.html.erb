<% Current.meta_tags.set(title: "Events") %>
<div class="container px-4 mx-auto my-8">
  <div class="flex items-center justify-between mb-4">
    <h1 class="h3">Events Calendar</h1>
    <div class="flex items-center gap-2">
      <%= link_to t("scaffold.new.title", model: "Event"), new_event_path, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="p-8 bg-white dark:bg-gray-900 dark:border dark:border-gray-700 rounded shadow">
    <div data-controller="calendar" data-calendar-events-url-value="<%= calendar_events_path(format: :json) %>"></div>
  </div>
</div>
