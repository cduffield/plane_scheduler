<div id="<%= dom_id event %>">
  <div class="grid gap-5 md:grid-cols-3">
    <div>
      <p class="sky-kicker">Start time</p>
      <p class="mt-1 text-sm font-semibold"><%= event.start_time %></p>
    </div>
    <div>
      <p class="sky-kicker">End time</p>
      <p class="mt-1 text-sm font-semibold"><%= event.end_time %></p>
    </div>
    <div>
      <p class="sky-kicker">Airplane</p>
      <p class="mt-1 text-sm font-semibold"><%= event.airplane&.n_number.presence || event.airplane_id %></p>
    </div>
    <div>
      <p class="sky-kicker">Flight instructor</p>
      <p class="mt-1 text-sm font-semibold"><%= event.flight_instructor&.name.presence || "None" %></p>
    </div>
    <div>
      <p class="sky-kicker">Booked by</p>
      <p class="mt-1 text-sm font-semibold"><%= event.user&.name.presence || "Unknown" %></p>
    </div>
    <div>
      <p class="sky-kicker">Status</p>
      <p class="mt-1"><span class="sky-badge"><%= event.status.titleize %></span></p>
    </div>
    <div>
      <p class="sky-kicker">Tach</p>
      <p class="mt-1 text-sm font-semibold tabular-nums"><%= event.tach_start %> → <%= event.tach_end %></p>
    </div>
    <div>
      <p class="sky-kicker">Hobbs</p>
      <p class="mt-1 text-sm font-semibold tabular-nums"><%= event.hobbs_start %> → <%= event.hobbs_end %></p>
    </div>
    <div>
      <p class="sky-kicker">Total cost</p>
      <p class="mt-1 text-lg font-bold tabular-nums"><%= event.total_cost.present? ? number_to_currency(event.total_cost) : nil %></p>
    </div>
  </div>

  <% if action_name != "show" %>
    <div class="mt-6">
      <%= link_to "View this event", event, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
