<%= form_with(model: event, data: (event.new_record? ? { controller: "event-form" } : {})) do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :start_time %>
    <div class="datetime-select">
      <%= form.datetime_select :start_time,
        {
          minute_step: 15,
          order: [:month, :day, :year],
          date_separator: "",
          time_separator: "",
          datetime_separator: tag.span("at", class: "datetime-select__separator"),
          use_short_month: true
        },
        {
          class: "form-control",
          data: {
            action: (form.object.new_record? ? "change->event-form#syncEndTime" : nil),
            event_form_target: "startPart"
          }
        } %>
    </div>
    <p class="form-hint">Choose the departure date and time in 15-minute increments.</p>
  </div>

  <div class="form-group">
    <%= form.label :end_time %>
    <div class="datetime-select">
      <%= form.datetime_select :end_time,
        {
          minute_step: 15,
          order: [:month, :day, :year],
          date_separator: "",
          time_separator: "",
          datetime_separator: tag.span("at", class: "datetime-select__separator"),
          use_short_month: true
        },
        {
          class: "form-control",
          data: {
            event_form_target: "endPart"
          }
        } %>
    </div>
    <p class="form-hint">Choose the return date and time in 15-minute increments.</p>
  </div>

  <div class="form-group">
    <%= form.label :airplane_id, "Airplane" %>
    <%= form.collection_select :airplane_id, Airplane.order(:n_number), :id, :n_number, { prompt: "Select an airplane" }, { class: "form-control" } %>
  </div>

  <% unless form.object.new_record? %>
    <div class="form-group">
      <%= form.label :status %>
      <%= form.select :status, Event.statuses.keys.map { |status| [status.titleize, status] }, {}, { class: "form-control" } %>
    </div>

    <div class="form-group">
      <%= form.label :tach_start %>
      <%= form.number_field :tach_start, class: "form-control", step: 0.1 %>
    </div>

    <div class="form-group">
      <%= form.label :tach_end %>
      <%= form.number_field :tach_end, class: "form-control", step: 0.1 %>
    </div>

    <div class="form-group">
      <%= form.label :hobbs_start %>
      <%= form.number_field :hobbs_start, class: "form-control", step: 0.1 %>
    </div>

    <div class="form-group">
      <%= form.label :hobbs_end %>
      <%= form.number_field :hobbs_end, class: "form-control", step: 0.1 %>
    </div>
  <% end %>

  <div>
    <%= form.button button_text(form.send(:submit_default_value)), class: "btn btn-primary" %>

    <% if form.object.new_record? %>
      <%= link_to t("cancel"), events_path, class: "btn btn-secondary" %>
    <% else %>
      <%= link_to t("cancel"), event_path(@event), class: "btn btn-secondary" %>
    <% end %>
  </div>
<% end %>
