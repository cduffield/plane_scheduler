<% Current.meta_tags.set(title: "Airplanes") %>
<%= turbo_stream_from :airplanes %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker">Fleet</p>
        <h1 class="h3">Airplanes</h1>

        <div class="text-sm font-medium sky-muted">
          <span>Sort by:</span>
          <%= sortable @airplanes, :n_number, "N number", class: "mr-1" %>
        </div>
      </div>
    </div>

    <%= link_to t("scaffold.new.title", model: "Airplane"), new_airplane_path, class: "btn btn-secondary" if Current.account_admin? %>
  </div>

  <%= tag.div id: ("airplanes" if @pagy.page == 1), class: "sky-card sky-card-pad space-y-8" do %>
    <%= render partial: "airplanes/airplane", collection: @airplanes, as: :airplane, cached: true %>

    <div class="hidden only:block sky-empty">
      <p class="mb-4 h3">Create your first Airplane</p>
      <%= link_to t("scaffold.new.title", model: "Airplane"), new_airplane_path, class: "btn btn-primary" if Current.account_admin? %>
    </div>
  <% end %>

  <% if @pagy.last > 1 %>
    <div class="my-6 text-center">
      <%== @pagy.series_nav %>
    </div>
  <% end %>
</div>
