<% Current.meta_tags.set(title: t("scaffold.new.title", model: "Airplane")) %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to "Airplanes", airplanes_path %></p>
        <h1 class="h3"><%= t("scaffold.new.title", model: "Airplane") %></h1>
      </div>
    </div>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render "form", airplane: @airplane %>
  </div>
</div>
