<% Current.meta_tags.set(title: "Airplanes ##{@airplane.id}") %>
<%= turbo_stream_from @airplane %>
<% can_manage_airplane = user_signed_in? && Current.account_admin? %>
<% can_manage_checkouts = user_signed_in? && (Current.account_admin? || Current.account_user&.flight_instructor?) %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to "Airplanes", airplanes_path %></p>
        <h1 class="h3">Airplane #<%= @airplane.id %></h1>
      </div>
    </div>
    <% if can_manage_airplane %>
      <div class="flex items-center gap-2">
        <%= link_to "Add Inspection", new_airplane_maintenance_inspection_path(@airplane), class: "btn btn-primary" %>
        <%= link_to t("edit"), edit_airplane_path(@airplane), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render @airplane %>
  </div>

  <div class="mt-8 sky-card sky-card-pad">
    <div class="flex items-center justify-between mb-6">
      <div>
        <p class="sky-kicker">Dispatch Rules</p>
        <h2 class="h4">Solo Rental Requirements</h2>
      </div>
      <% if can_manage_airplane %>
        <%= link_to "Edit Requirements", edit_airplane_path(@airplane), class: "btn btn-secondary" %>
      <% end %>
    </div>

    <% if (requirement = @airplane.airplane_solo_requirement)&.active? %>
      <dl class="grid gap-4 md:grid-cols-4">
        <div>
          <dt class="sky-kicker">Checkout</dt>
          <dd class="mt-1 text-sm"><%= requirement.requires_checkout? ? "Required" : "Not required" %></dd>
        </div>
        <div>
          <dt class="sky-kicker">Certificate</dt>
          <dd class="mt-1 text-sm"><%= requirement.required_certificate_type_label.presence || "Not required" %></dd>
        </div>
        <div>
          <dt class="sky-kicker">Rating</dt>
          <dd class="mt-1 text-sm"><%= requirement.required_rating_type_label.presence || "Not required" %></dd>
        </div>
        <div>
          <dt class="sky-kicker">Recent Rental</dt>
          <dd class="mt-1 text-sm"><%= requirement.recent_rental_days.present? ? "Within #{requirement.recent_rental_days} days" : "Not required" %></dd>
        </div>
      </dl>
    <% else %>
      <div class="sky-empty">Solo rental requirements are not enabled for this airplane.</div>
    <% end %>
  </div>

  <% if can_manage_checkouts %>
    <div class="mt-8 sky-card sky-card-pad">
      <div class="mb-6">
        <p class="sky-kicker">Dispatch Rules</p>
        <h2 class="h4">Pilot Checkouts</h2>
        <p class="sky-muted mt-1 text-sm">Mark pilots as checked out for this aircraft so they can satisfy solo rental requirements.</p>
      </div>

      <% qualifications = @airplane.airplane_user_qualifications.includes(:user, :approved_by).order(created_at: :desc) %>
      <% if qualifications.any? %>
        <div class="overflow-x-auto rounded-xl border mb-6" style="border-color: var(--sky-border);">
          <table class="sky-table">
            <thead>
              <tr>
                <th>Pilot</th>
                <th>Completed</th>
                <th>Expires</th>
                <th>Approved by</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <% qualifications.each do |qualification| %>
                <tr>
                  <td><%= qualification.user.name.presence || qualification.user.email %></td>
                  <td><%= qualification.checkout_completed_at.present? ? l(qualification.checkout_completed_at, format: :long) : "Not recorded" %></td>
                  <td><%= qualification.expires_on.present? ? l(qualification.expires_on, format: :long) : "No expiration" %></td>
                  <td><%= qualification.approved_by&.name.presence || "Unknown" %></td>
                  <td><%= qualification.notes.presence || "-" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="sky-empty mb-6">No pilot checkouts have been recorded for this aircraft.</div>
      <% end %>

      <%= form_with url: airplane_user_qualifications_path(@airplane), scope: :airplane_user_qualification, class: "sky-modal-form" do |form| %>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="form-group">
            <%= form.label :user_id, "Pilot" %>
            <%= form.collection_select :user_id,
              current_account.users.order(:first_name, :last_name, :email),
              :id,
              :name,
              { prompt: "Select pilot" },
              { class: "form-control" } %>
          </div>

          <div class="form-group">
            <%= form.label :checkout_completed_at, "Completed on" %>
            <%= form.date_field :checkout_completed_at, value: Date.current.iso8601, class: "form-control" %>
          </div>

          <div class="form-group">
            <%= form.label :expires_on, "Expires on" %>
            <%= form.date_field :expires_on, class: "form-control" %>
          </div>

          <div class="form-group">
            <%= form.label :notes %>
            <%= form.text_field :notes, class: "form-control", placeholder: "Checkout notes" %>
          </div>
        </div>

        <div class="mt-4">
          <%= form.button "Mark checked out", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-8 sky-card sky-card-pad">
    <div class="flex items-center justify-between mb-6">
      <div>
        <p class="sky-kicker">Airworthiness</p>
        <h2 class="h4">Maintenance Inspections</h2>
      </div>
      <% if can_manage_airplane %>
        <%= link_to "Add Inspection", new_airplane_maintenance_inspection_path(@airplane), class: "btn btn-secondary" %>
      <% end %>
    </div>

    <% if @airplane.maintenance_inspections.any? %>
      <div class="space-y-4">
        <% @airplane.maintenance_inspections.order(created_at: :desc).each do |inspection| %>
          <div class="sky-panel p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="sky-section-title"><%= inspection.name %></h3>
                <% if inspection.description.present? %>
                  <p class="mt-1 text-sm sky-muted"><%= inspection.description %></p>
                <% end %>
              </div>

              <% if can_manage_airplane %>
                <%= link_to "Edit", edit_airplane_maintenance_inspection_path(@airplane, inspection), class: "btn btn-secondary" %>
              <% end %>
            </div>

            <dl class="mt-4 grid gap-4 md:grid-cols-4">
              <div>
                <dt class="sky-kicker">Tracking</dt>
                <dd class="mt-1 text-sm"><%= inspection.tracking_type.titleize %></dd>
              </div>

              <div>
                <dt class="sky-kicker">Calendar Rule</dt>
                <dd class="mt-1 text-sm">
                  <% if inspection.calendar_interval_value.present? && inspection.calendar_interval_unit.present? %>
                    Every <%= inspection.calendar_interval_value %> <%= inspection.calendar_interval_unit %>
                  <% else %>
                    Not used
                  <% end %>
                </dd>
              </div>

              <div>
                <dt class="sky-kicker">Hour Rule</dt>
                <dd class="mt-1 text-sm">
                  <% if inspection.hour_interval_value.present? && inspection.hour_interval_type.present? %>
                    Every <%= inspection.hour_interval_value %> <%= inspection.hour_interval_type %> hours
                  <% else %>
                    Not used
                  <% end %>
                </dd>
              </div>

              <div>
                <dt class="sky-kicker">Status</dt>
                <dd class="mt-1"><span class="<%= inspection.active? ? "sky-badge" : "sky-badge sky-badge-muted" %>"><%= inspection.active? ? "Active" : "Inactive" %></span></dd>
              </div>

              <div>
                <dt class="sky-kicker">Last Performed</dt>
                <dd class="mt-1 text-sm">
                  <%= inspection.latest_event&.performed_at.present? ? l(inspection.latest_event.performed_at, format: :long) : "Never recorded" %>
                </dd>
              </div>
            </dl>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="sky-empty">No maintenance inspections have been added for this airplane yet.</div>
    <% end %>
  </div>
</div>
