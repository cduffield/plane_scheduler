<%= form_with(model: airplane) do |form| %>
  <%= render "error_messages", resource: form.object %>

  <div class="form-group">
    <%= form.label :n_number %>
    <%= form.text_field :n_number, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :hobbs_time %>
    <%= form.number_field :hobbs_time, class: "form-control", step: 0.1 %>
  </div>

  <div class="form-group">
    <%= form.label :tach_time %>
    <%= form.number_field :tach_time, class: "form-control", step: 0.1 %>
  </div>

  <div class="form-group">
    <%= form.label :rate, "Hourly rate" %>
    <%= form.number_field :rate, class: "form-control", step: 0.01 %>
  </div>

  <div>
    <%= form.button button_text(form.send(:submit_default_value)), class: "btn btn-primary" %>

    <% if form.object.new_record? %>
      <%= link_to t("cancel"), airplanes_path, class: "btn btn-secondary" %>
    <% else %>
      <%= link_to t("cancel"), airplane_path(@airplane), class: "btn btn-secondary" %>
    <% end %>
  </div>
<% end %>
