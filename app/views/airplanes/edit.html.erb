<% Current.meta_tags.set(title: t("scaffold.edit.title", model: "Airplane")) %>

<div class="container mx-auto px-4 my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">✈</span>
      <div>
        <p class="sky-kicker"><%= link_to "Airplanes", airplanes_path %></p>
        <h1 class="h3"><%= t("scaffold.edit.title", model: "Airplane") %></h1>
      </div>
    </div>
    <%= button_to t("delete"), @airplane, method: :delete, class: "btn btn-secondary", form: { data: { turbo_confirm: t("are_you_sure") } } %>
  </div>

  <div class="sky-card sky-card-pad">
    <%= render "form", airplane: @airplane %>
  </div>
</div>
