<div class="sky-profile-rating-card" data-certificate-record>
  <%= form.hidden_field :id %>
  <%= form.hidden_field :_destroy, value: "0" %>

  <div class="sky-profile-rating-grid">
    <div class="form-group">
      <%= form.label :certificate_type, "Certificate / Rating" %>
      <%= form.select :certificate_type,
        UserPilotCertificate::CERTIFICATE_TYPES.map { |value, label| [label, value] },
        { include_blank: "Select" },
        class: "form-control sky-profile-input" %>
    </div>

    <div class="form-group">
      <%= form.label :category, "Category" %>
      <%= form.select :category,
        UserPilotCertificate::CATEGORIES.map { |value, label| [label, value] },
        { include_blank: "Select" },
        class: "form-control sky-profile-input" %>
    </div>

    <div class="form-group">
      <%= form.label :aircraft_class, "Class" %>
      <%= form.select :aircraft_class,
        UserPilotCertificate::CLASSES.map { |value, label| [label, value] },
        { include_blank: "Select" },
        class: "form-control sky-profile-input" %>
    </div>

    <div class="form-group">
      <%= form.label :certificate_number, "Certificate #" %>
      <%= form.text_field :certificate_number, class: "form-control sky-profile-input" %>
    </div>

    <div class="form-group">
      <%= form.label :issued_on, "Issued on" %>
      <%= form.date_field :issued_on, class: "form-control sky-profile-input" %>
    </div>

    <div class="form-group sky-profile-rating-remove-wrap">
      <button type="button" class="btn btn-secondary sky-profile-remove-rating" data-action="pilot-certificates#remove">Remove</button>
    </div>
  </div>
</div>
