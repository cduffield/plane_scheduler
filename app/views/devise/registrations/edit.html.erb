<% Current.meta_tags.set(title: "My Profile") %>
<% new_certificate_records = resource.user_pilot_certificates.reject { |certificate| certificate.persisted? || certificate.marked_for_destruction? } %>
<% new_certificate_records << UserPilotCertificate.new if new_certificate_records.empty? %>
<% persisted_certificate_count = resource.user_pilot_certificates.count(&:persisted?) %>
<% medical_certificate = resource.user_medical_certificate || resource.build_user_medical_certificate %>

<div class="sky-profile-shell">
  <header class="sky-profile-header">
    <div class="sky-profile-header-inner">
      <div class="flex items-center gap-3">
        <span class="sky-profile-icon" aria-hidden="true"></span>
        <h1>My Profile</h1>
      </div>
      <%= link_to "Back", root_path, class: "sky-profile-back" %>
    </div>
  </header>

  <main class="sky-profile-main">
    <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), method: :put, class: "space-y-6", data: { controller: "bridge--form pilot-certificates", action:"turbo:submit-start->bridge--form#submitStart turbo:submit-end->bridge--form#submitEnd" }) do |form| %>
      <%= render "error_messages", resource: resource %>

      <section class="sky-profile-card">
        <div class="sky-profile-card-header">
          <h2>Account Details</h2>
          <p>Basic information about you.</p>
        </div>

        <div class="sky-profile-avatar-row">
          <%= image_tag avatar_url_for(form.object), class: "sky-profile-avatar-large" %>
          <div class="form-group sky-profile-avatar-upload">
            <%= form.label :avatar %>
            <%= form.file_field :avatar, accept: "image/png, image/jpeg, image/heic, image/heif, image/webp", class: "sky-profile-file-input" %>
          </div>
        </div>

        <div class="sky-profile-grid">
          <div class="form-group">
            <%= form.label :name, "Full name" %>
            <%= form.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Jane Doe", class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :email %>
            <%= form.email_field :email, autocomplete: "email", class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :phone %>
            <%= form.telephone_field :phone, autocomplete: "tel", class: "form-control sky-profile-input" %>
          </div>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="alert alert-warning mt-4"><%= t('.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %></div>
        <% end %>
      </section>

      <section class="sky-profile-card">
        <div class="sky-profile-card-header sky-profile-title-row">
          <div>
            <div class="flex items-center gap-2">
              <span class="sky-profile-icon-small" aria-hidden="true"></span>
              <h2>Pilot Certificates & Ratings</h2>
            </div>
            <p>Add each certificate or rating you hold, with category and class.</p>
          </div>
        </div>

        <div class="sky-profile-rating-list">
          <%= form.fields_for :user_pilot_certificates do |certificate_form| %>
            <% certificate = certificate_form.object %>
            <% next unless certificate.persisted? && !certificate.marked_for_destruction? %>
            <div class="sky-profile-rating-summary">
              <%= certificate_form.hidden_field :id %>
              <%= certificate_form.hidden_field :_destroy, value: "0" %>
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <strong><%= certificate.certificate_type_label %></strong>
                  <span class="sky-badge sky-badge-muted"><%= certificate.category_label %></span>
                  <span class="sky-badge sky-badge-muted"><%= certificate.aircraft_class_label %></span>
                </div>
                <p>
                  <% if certificate.certificate_number.present? %>Cert #: <%= certificate.certificate_number %><% end %>
                  <% if certificate.certificate_number.present? && certificate.issued_on.present? %> - <% end %>
                  <% if certificate.issued_on.present? %>Issued: <%= certificate.issued_on.iso8601 %><% end %>
                </p>
              </div>
              <button type="button" class="sky-profile-delete-rating" aria-label="Remove pilot certificate" data-action="pilot-certificates#remove"></button>
            </div>
          <% end %>
        </div>

        <div class="sky-profile-divider"></div>

        <h3 class="sky-profile-subtitle">Add a rating</h3>
        <div data-pilot-certificates-target="list">
          <% new_certificate_records.each_with_index do |certificate, index| %>
            <%= form.fields_for :user_pilot_certificates, certificate, child_index: persisted_certificate_count + index do |certificate_form| %>
              <%= render "pilot_certificate_fields", form: certificate_form %>
            <% end %>
          <% end %>
        </div>

        <template data-pilot-certificates-target="template">
          <%= form.fields_for :user_pilot_certificates, UserPilotCertificate.new, child_index: "NEW_RECORD" do |certificate_form| %>
            <%= render "pilot_certificate_fields", form: certificate_form %>
          <% end %>
        </template>

        <button type="button" class="btn btn-secondary" data-action="pilot-certificates#add">+ Add another rating</button>
      </section>

      <section class="sky-profile-card">
        <div class="sky-profile-card-header">
          <div class="flex items-center gap-2">
            <span class="sky-profile-medical-icon" aria-hidden="true"></span>
            <h2>Medical Certificate</h2>
          </div>
          <p>Keep your medical certificate information current.</p>
        </div>

        <%= form.fields_for :user_medical_certificate, medical_certificate do |medical_form| %>
          <%= medical_form.hidden_field :id if medical_form.object.persisted? %>

          <div class="sky-profile-grid">
            <div class="form-group">
              <%= medical_form.label :medical_class, "Class" %>
              <%= medical_form.select :medical_class,
                UserMedicalCertificate::MEDICAL_CLASSES.map { |value, label| [label, value] },
                { include_blank: "Select class" },
                class: "form-control sky-profile-input" %>
            </div>

            <div class="form-group">
              <%= medical_form.label :certificate_number, "Certificate #" %>
              <%= medical_form.text_field :certificate_number, class: "form-control sky-profile-input" %>
            </div>

            <div class="form-group">
              <%= medical_form.label :issued_on, "Issued on" %>
              <%= medical_form.date_field :issued_on, class: "form-control sky-profile-input" %>
            </div>

            <div class="form-group">
              <%= medical_form.label :expires_on, "Expires on" %>
              <%= medical_form.date_field :expires_on, class: "form-control sky-profile-input" %>
            </div>
          </div>
        <% end %>
      </section>

      <section class="sky-profile-card">
        <div class="sky-profile-card-header">
          <div class="flex items-center gap-2">
            <span class="sky-profile-hours-icon" aria-hidden="true"></span>
            <h2>Total Hours</h2>
          </div>
          <p>Update your logged flight-hour totals.</p>
        </div>

        <div class="sky-profile-hours-grid">
          <div class="form-group">
            <%= form.label :total_time, "Total time" %>
            <%= form.number_field :total_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :pic_time, "PIC" %>
            <%= form.number_field :pic_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :sic_time, "SIC" %>
            <%= form.number_field :sic_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :cross_country_time, "Cross-country" %>
            <%= form.number_field :cross_country_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :instrument_time, "Instrument" %>
            <%= form.number_field :instrument_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :night_time, "Night" %>
            <%= form.number_field :night_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :simulator_time, "Simulator" %>
            <%= form.number_field :simulator_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :dual_received_time, "Dual received" %>
            <%= form.number_field :dual_received_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>

          <div class="form-group">
            <%= form.label :solo_time, "Solo" %>
            <%= form.number_field :solo_time, step: 0.1, min: 0, class: "form-control sky-profile-input" %>
          </div>
        </div>
      </section>

      <div class="sky-profile-actions">
        <%= form.button button_text(t('.update'), disable_with: t(".saving")), class: "btn btn-primary", "data-bridge--form-target": "submit", "data-bridge-title": t('.update') %>
      </div>
    <% end %>

    <section class="sky-profile-card sky-profile-danger-card">
      <div>
        <h2><%= t(".cancel_my_account") %></h2>
        <p><%= t(".cancel_my_account_description") %></p>
      </div>

      <%= button_to t(".cancel_my_account"), registration_path(resource_name),
        method: :delete,
        class: "btn btn-danger btn-outline sky-profile-cancel-account",
        data: {
          controller: "bridge--sign-out",
          action: "bridge--sign-out#signOut",
          bridge__sign_out_path_value: api_v1_me_path,
          turbo_confirm: t("are_you_sure"),
          turbo_confirm_text: current_user.email,
          turbo_confirm_description: t(".cancel_my_account_confirm_description_html")
        } %>
    </section>
  </main>
</div>
