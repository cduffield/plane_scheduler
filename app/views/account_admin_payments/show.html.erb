<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">$</span>
      <div>
        <p class="sky-kicker"><%= link_to "Account Admin", account_admin_path %></p>
        <h1 class="text-3xl font-black tracking-tight">Payment Settings</h1>
        <p class="sky-muted mt-1">Connect this account's Stripe account to accept direct flight payments.</p>
      </div>
    </div>

    <%= link_to "Back to Account Admin", account_admin_path, class: "btn btn-secondary" %>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <section class="sky-card sky-card-pad lg:col-span-2">
      <h2 class="sky-section-title mb-2">Stripe Connect</h2>
      <p class="sky-muted mb-6">
        Payments for this team are created directly on the connected Stripe account. Stripe collects business and bank details during onboarding.
      </p>

      <div class="sky-panel p-5 mb-6">
        <p class="sky-kicker">Connection status</p>
        <% if @merchant&.processor_id.present? %>
          <p class="font-extrabold mt-2"><%= @merchant.processor_id %></p>
          <% if @merchant.onboarding_complete? %>
            <span class="sky-badge mt-3">Ready to accept payments</span>
          <% else %>
            <span class="sky-badge sky-badge-muted mt-3">Setup incomplete</span>
          <% end %>
        <% else %>
          <p class="font-extrabold mt-2">Not connected</p>
          <span class="sky-badge sky-badge-muted mt-3">Stripe setup required</span>
        <% end %>
      </div>

      <% if @stripe_connect_error.present? %>
        <div class="sky-panel p-5 mb-6 border-red-200 bg-red-50">
          <p class="font-bold text-red-700">Could not refresh Stripe status</p>
          <p class="sky-muted text-sm mt-1"><%= @stripe_connect_error %></p>
        </div>
      <% elsif @stripe_connect_status.present? %>
        <div class="sky-panel p-5 mb-6">
          <h3 class="font-extrabold mb-4">Stripe status details</h3>

          <dl class="grid gap-4 sm:grid-cols-3">
            <div>
              <dt class="sky-kicker">Charges</dt>
              <dd class="font-bold mt-1"><%= @stripe_connect_status[:charges_enabled] ? "Enabled" : "Disabled" %></dd>
            </div>
            <div>
              <dt class="sky-kicker">Payouts</dt>
              <dd class="font-bold mt-1"><%= @stripe_connect_status[:payouts_enabled] ? "Enabled" : "Disabled" %></dd>
            </div>
            <div>
              <dt class="sky-kicker">Details submitted</dt>
              <dd class="font-bold mt-1"><%= @stripe_connect_status[:details_submitted] ? "Yes" : "No" %></dd>
            </div>
          </dl>

          <% if @stripe_connect_status[:disabled_reason].present? %>
            <div class="mt-5">
              <p class="sky-kicker">Disabled reason</p>
              <dd class="font-bold mt-1"><%= @stripe_connect_status[:disabled_reason] %></dd>
            </div>
          <% end %>

          <% required_items = (@stripe_connect_status[:currently_due] + @stripe_connect_status[:past_due]).uniq %>
          <% if required_items.any? %>
            <div class="mt-5">
              <p class="sky-kicker">Stripe still needs</p>
              <ul class="list-disc pl-5 mt-2 sky-muted">
                <% required_items.each do |item| %>
                  <li><%= item.to_s.tr("._", "  ").squish %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= button_to (@merchant&.processor_id.present? ? "Continue Stripe setup" : "Connect Stripe"), account_admin_payments_path, method: :post, class: "btn btn-primary", form: { data: { turbo: false } } %>
    </section>

    <aside class="sky-card sky-card-pad">
      <h2 class="sky-section-title mb-2">Direct charges</h2>
      <p class="sky-muted text-sm">
        Customers pay this team's connected Stripe account. The team is the merchant of record and Stripe fees are charged to the connected account.
      </p>
    </aside>
  </div>
</div>
