<% Current.meta_tags.set(title: "Payment History") %>

<div class="container px-4 mx-auto my-8 sky-shell">
  <div class="sky-page-header">
    <div class="flex items-center gap-3">
      <span class="sky-brand-mark">$</span>
      <div>
        <p class="sky-kicker">Billing</p>
        <h1 class="h3">Payment History</h1>
        <p class="text-sm sky-muted">A record of your event payments and current payment status.</p>
      </div>
    </div>
  </div>

  <% if @unpaid_event_payments.any? || @paid_event_payments.any? %>
    <div class="space-y-8">
      <div class="sky-card overflow-hidden">
        <div class="px-6 py-4 border-b" style="border-color: var(--sky-border)">
          <h2 class="sky-section-title">Unpaid</h2>
        </div>

        <% if @unpaid_event_payments.any? %>
          <div class="overflow-x-auto">
            <table class="sky-table">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Airplane</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @unpaid_event_payments.each do |event_payment| %>
                  <tr>
                    <td>Event #<%= event_payment.event_id %></td>
                    <td><%= event_payment.event.airplane&.n_number.presence || "-" %></td>
                    <td><%= number_to_currency(event_payment.amount) %></td>
                    <td><span class="sky-badge sky-badge-muted"><%= event_payment.status.titleize %></span></td>
                    <td>
                      <%= link_to "View Event", event_path(event_payment.event), class: "text-primary dark:text-white hover:underline" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-6 text-sm sky-muted">No unpaid event payments.</div>
        <% end %>
      </div>

      <div class="sky-card overflow-hidden">
        <div class="px-6 py-4 border-b" style="border-color: var(--sky-border)">
          <h2 class="sky-section-title">Paid</h2>
        </div>

        <% if @paid_event_payments.any? %>
          <div class="overflow-x-auto">
            <table class="sky-table">
              <thead>
                <tr>
                  <th>Event</th>
                  <th>Airplane</th>
                  <th>Amount</th>
                  <th>Paid At</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @paid_event_payments.each do |event_payment| %>
                  <tr>
                    <td>Event #<%= event_payment.event_id %></td>
                    <td><%= event_payment.event.airplane&.n_number.presence || "-" %></td>
                    <td><%= number_to_currency(event_payment.amount) %></td>
                    <td><%= event_payment.paid_at.present? ? l(event_payment.paid_at, format: :long) : "-" %></td>
                    <td>
                      <%= link_to "View Event", event_path(event_payment.event), class: "text-primary dark:text-white hover:underline" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-6 text-sm sky-muted">No paid event payments yet.</div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="sky-card sky-card-pad">
      <div class="sky-empty">
        <p class="mb-2 text-lg font-medium">No payments yet</p>
        <p class="text-sm">Once you pay for a closed event, it will show up here.</p>
      </div>
    </div>
  <% end %>
</div>
