<div class="mt-4 p-4 bg-white rounded-lg border border-gray-200 lg:p-10">
  <h3><%= t(".title") %></h3>
  <p class="mb-4 text-sm text-gray-700"><%= t(".description") %></p>

  <%= form_with url: account_transfer_path(account), method: :patch do |form| %>
    <div class="form-group">
      <%= form.label :user_id %>
      <% transfer_user_options = account.users.where.not(users: { id: current_user.id }).map { |user| [user.name, user.signed_id(purpose: :account_transfer)] } %>
      <%= form.select :user_id, options_for_select(transfer_user_options), { prompt: true }, { class: "form-control" } %>
    </div>

    <%= form.button t(".transfer"), class: "btn btn-primary", data: { turbo_confirm: t(".are_you_sure") } %>
  <% end %>
</div>
